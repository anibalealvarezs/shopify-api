{
  "name": "anibalealvarezs/shopify-api",
  "description": "Standardized Shopify Admin API client for data extraction and integration within the APIs Hub ecosystem.",
  "license": "MIT",
  "keywords": [
    "shopify-api",
    "ecommerce",
    "apis-hub",
    "data-extraction",
    "php",
    "guzzle"
  ],
  "homepage": "https://github.com/anibalealvarezs/shopify-api",
  "authors": [
    {
      "name": "Aníbal Álvarez",
      "email": "anibalealvarezs@gmail.com"
    }
  ],
  "support": {
    "issues": "https://github.com/anibalealvarezs/shopify-api/issues"
  },
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.0",
    "ext-json": "*",
    "symfony/yaml": "^6.0 || ^7.0",
    "nesbot/carbon": "^2.61 || ^3.0",
    "anibalealvarezs/api-client-skeleton": "dev-main",
    "monolog/monolog": "^2.0 || ^3.0",
    "psr/log": "^1.0 || ^2.0 || ^3.0"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://satis.anibalalvarez.com/"
    }
  ],
  "autoload": {
    "psr-4": {
      "Anibalealvarezs\\ShopifyApi\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9",
    "phpstan/phpstan": "^1.10"
  },
  "minimum-stability": "dev",
  "prefer-stable": false
}
